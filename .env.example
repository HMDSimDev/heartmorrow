# =============================================================================
# DSim — local environment configuration
# Copy this file to `.env` and adjust as needed. All values are optional;
# sane defaults are applied when unset. Runtime LLM settings can also be
# edited live from the in-app Settings page (stored in the local SQLite DB).
# =============================================================================

# --- Server -----------------------------------------------------------------
# Port the local Fastify API server listens on.
PORT=8787
# Host to bind. Keep it on localhost for a local-only app.
HOST=127.0.0.1

# Directory for the SQLite database file and uploaded assets.
# Relative paths are resolved from the server package root.
DATA_DIR=./data
UPLOADS_DIR=./data/uploads

# Comma-separated list of origins allowed by CORS (local dev only).
# The Vite dev server (http://localhost:5173) is allowed by default.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Default LLM provider settings ------------------------------------------
# These seed the initial settings row. Change them live in the Settings page.
# The BROWSER NEVER talks to the LLM directly — only this server does.
LLM_BASE_URL=http://localhost:1234/v1
# Optional. Local servers (LM Studio, Ollama, llama.cpp) usually ignore this.
LLM_API_KEY=lm-studio
LLM_MODEL=local-model
# Optional vision-capable model for image-based generation (e.g. drafting a
# character from a portrait). Reuses LLM_BASE_URL + LLM_API_KEY. Leave blank to
# fall back to LLM_MODEL (fine when your main model is already multimodal).
LLM_VISION_MODEL=
LLM_TEMPERATURE=0.8
# Reasoning models need plenty of room (they spend tokens "thinking"); 2048+ recommended.
LLM_MAX_TOKENS=2048
# Structured output mode: json_schema | json_object | prompt_only
# The server auto-downgrades if your endpoint rejects the chosen format, so any
# value works; json_schema is the strictest and most widely supported default.
LLM_STRUCTURED_MODE=json_schema
# Endpoint mode: chat_completions (only mode implemented today) | responses (reserved)
LLM_ENDPOINT_MODE=chat_completions
# Max structured-output repair retries before failing safely.
LLM_MAX_RETRIES=3

# --- Web (Vite) -------------------------------------------------------------
# Where the web client proxies API calls during dev. Usually matches PORT.
VITE_API_PROXY_TARGET=http://127.0.0.1:8787
